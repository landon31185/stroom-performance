# TODO(stroom): copy to `.env` and fill in real values. Never commit `.env`.
# Shopify Storefront API — powers live product/price/availability data + the
# `get_products` / `check_fitment` WebMCP tools. Read-only, public-safe token.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=replace_with_public_storefront_token
SHOPIFY_API_VERSION=2026-04
# Optional hosted customer-account URL. Add after new Customer Accounts is enabled.
PUBLIC_SHOPIFY_ACCOUNT_URL=

# Canonicals, sitemap, Open Graph, verification, and analytics.
PUBLIC_SITE_URL=https://stroomperformance.com
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=
PUBLIC_GA_MEASUREMENT_ID=

# Server-only endpoints. Never prefix these with PUBLIC_.
SHOPIFY_WEBHOOK_SECRET=replace_with_a_long_random_value
VERCEL_DEPLOY_HOOK_URL=
