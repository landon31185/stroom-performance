---
interface Props {
  src: string;
  poster?: string;
}

const { src, poster } = Astro.props;
---

<div class="hero-film-layer" aria-hidden="true">
  <div class="hero-film-layer__ambient">
    <video
      class="hero-film-layer__video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={poster}
    >
      <source src={src} type="video/mp4" />
    </video>
    <div class="hero-film-layer__shade"></div>
  </div>
  <div class="hero-film-layer__panel">
    <video
      class="hero-film-layer__panel-video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={poster}
    >
      <source src={src} type="video/mp4" />
    </video>
    <div class="hero-film-layer__panel-overlay"></div>
    <div class="hero-film-layer__panel-meta">
      <span class="hero-film-layer__meta-label">Live pass sample</span>
      <span class="hero-film-layer__meta-value">In-car proof</span>
    </div>
  </div>
</div>
