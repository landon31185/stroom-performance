---
import { platformName, systemName } from '../lib/site';
interface Props {
  slug: string;
  title: string;
  brand: string;
  system: string;
  platforms?: string[];
  summary: string;
  availability: 'in-stock' | 'build-to-order' | 'coming-soon';
  price?: number;
}
const { slug, title, brand, system, platforms = [], summary, availability, price } = Astro.props;
const availLabel = {
  'in-stock': 'In stock',
  'build-to-order': 'Build to order',
  'coming-soon': 'Coming soon',
}[availability];
---
<a href={`/products/${slug}`} class="product-card">
  <div class="product-card__top">
    <div class="product-card__facets">
      <span class="tag">{systemName(system)}</span>
      {platforms.map((platform) => <span class="tag tag-platform">{platformName(platform)}</span>)}
    </div>
    <span class="readout product-card__availability">{availLabel}</span>
  </div>
  <div class="product-card__body">
    <p class="muted product-card__brand">{brand}</p>
    <h3 class="heading-card product-card__title">{title}</h3>
  </div>
  <p class="muted product-card__summary">{summary}</p>
  <div class="product-card__footer">
    <span class="readout accent product-card__price">{price ? `$${price.toFixed(2)}` : 'Pricing soon'}</span>
    <span class="nav-link accent">View →</span>
  </div>
</a>
