---
import { systemName } from '../lib/site';
interface Props {
  slug: string;
  title: string;
  brand: string;
  system: string;
  summary: string;
  availability: 'in-stock' | 'build-to-order' | 'coming-soon';
  price?: number;
}
const { slug, title, brand, system, summary, availability, price } = Astro.props;
const availLabel = {
  'in-stock': 'In stock',
  'build-to-order': 'Build to order',
  'coming-soon': 'Coming soon',
}[availability];
---
<a href={`/products/${slug}`} class="card" style="display:flex;flex-direction:column;gap:0.75rem;padding:1.25rem;text-decoration:none;">
  <div style="display:flex;justify-content:space-between;align-items:start;gap:0.5rem;">
    <span class="tag">{systemName(system)}</span>
    <span class="readout" style="font-size:0.6875rem;color:var(--color-ink-muted);text-transform:uppercase;letter-spacing:0.06em;">{availLabel}</span>
  </div>
  <div>
    <p class="muted" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;">{brand}</p>
    <h3 class="heading-card" style="margin-top:0.15rem;">{title}</h3>
  </div>
  <p class="muted" style="font-size:0.875rem;line-height:1.55;flex:1;">{summary}</p>
  <div style="display:flex;justify-content:space-between;align-items:center;">
    <span class="readout accent" style="font-weight:600;">{price ? `$${price.toFixed(2)}` : 'Pricing soon'}</span>
    <span class="nav-link accent">View →</span>
  </div>
</a>
