---
import { platformName, systemName } from '../lib/site';
import ProductMedia from './ProductMedia.astro';
import { formatMoney, statusLabels } from '../lib/catalog';
import type { CatalogStatus, Money } from '../lib/shopify';
interface Props {
  slug: string;
  title: string;
  brand: string;
  system: string;
  platforms?: string[];
  summary: string;
  status: CatalogStatus;
  price?: Money;
  partNumber?: string;
  image?: string;
  imageAlt?: string;
}
const { slug, title, brand, system, platforms = [], summary, status, price, partNumber, image, imageAlt } = Astro.props;
const ctaLabel = status === 'available' ? 'View product' : 'Preview details';
---
<a href={`/products/${slug}`} class="product-card">
  <ProductMedia {slug} {title} {brand} {partNumber} {image} {imageAlt} />
  <div class="product-card__top">
    <div class="product-card__facets">
      <span class="tag">{systemName(system)}</span>
      {platforms.map((platform) => <span class="tag tag-platform">{platformName(platform)}</span>)}
    </div>
    <span class="readout product-card__availability">{statusLabels[status]}</span>
  </div>
  <div class="product-card__body">
    <p class="muted product-card__brand">{brand}</p>
    <h3 class="heading-card product-card__title">{title}</h3>
  </div>
  <p class="muted product-card__summary">{summary}</p>
  <div class="product-card__footer">
    <span class="readout accent product-card__price">{formatMoney(price)}</span>
    <span class="nav-link accent">{ctaLabel} →</span>
  </div>
</a>
