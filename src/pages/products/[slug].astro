---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection, render } from 'astro:content';
import { site, systemName, raceStyleName, platformName } from '../../lib/site';
import ProductMedia from '../../components/ProductMedia.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((p) => ({ params: { slug: p.id }, props: { product: p } }));
}

const { product } = Astro.props;
const d = product.data;
const { Content } = await render(product);

const availabilityMap: Record<string, string> = {
  'in-stock': 'https://schema.org/InStock',
  'build-to-order': 'https://schema.org/BackOrder',
  'coming-soon': 'https://schema.org/PreOrder',
};
const availLabel: Record<string, string> = {
  'in-stock': 'In stock',
  'build-to-order': 'Build to order — lead time applies',
  'coming-soon': 'Coming soon',
};
const confidenceLabel: Record<string, string> = {
  'verified-on-car': 'Verified on our car',
  'vendor-stated': 'Vendor-stated',
  'inferred': 'Inferred — confirm before purchase',
};

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: d.title,
  description: d.summary,
  brand: { '@type': 'Brand', name: d.brand },
  ...(d.manufacturerPartNumber ? { mpn: d.manufacturerPartNumber, sku: d.manufacturerPartNumber } : {}),
  category: systemName(d.system),
  ...(d.image ? { image: `${site.url}${d.image}` } : {}),
  offers: {
    '@type': 'Offer',
    availability: availabilityMap[d.availability],
    url: `${site.url}/products/${product.id}`,
    seller: { '@id': `${site.url}/#store` },
    ...(d.price ? { price: d.price.toFixed(2), priceCurrency: 'USD' } : {}),
  },
});
---

<BaseLayout
  title={`${d.title} | Stroom Performance`}
  description={d.summary}
  ogType="article"
  schema={`<script type="application/ld+json">${schema}<\/script>`}
>
  <section class="product-hero">
    <div class="wrap product-hero__wrap">
      <div class="product-hero__copy">
        <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Shop', href: '/shop' }, { label: systemName(d.system), href: `/collections/${d.system}` }, { label: d.title }]} />
        <ProductMedia slug={product.id} title={d.title} brand={d.brand} partNumber={d.manufacturerPartNumber} image={d.image} size="hero" />
        <div class="product-hero__tags reveal">
          <span class="tag">{systemName(d.system)}</span>
          {d.platforms.map((platform) => <span class="tag tag-platform">{platformName(platform)}</span>)}
          {d.raceStyles.map((r) => <span class="tag tag-hazard">{raceStyleName(r)}</span>)}
        </div>
        <p class="muted product-hero__brand reveal">{d.brand}</p>
        <h1 class="heading-section product-hero__title reveal">{d.title}</h1>
        <p class="body-large muted product-hero__body reveal">{d.summary}</p>
      </div>

      <aside class="product-buybox reveal">
        <p class="product-buybox__price readout accent">{d.price ? `$${d.price.toFixed(2)}` : 'Pricing soon'}</p>
        <p class="muted product-buybox__availability">{availLabel[d.availability]}</p>

        <!-- TODO(stroom): wire to Shopify cart once Storefront API + product exist. -->
        <button class="btn-primary product-buybox__cta" disabled aria-disabled="true">
          {d.availability === 'coming-soon' ? 'Notify me' : 'Add to cart'}
        </button>
        <p class="muted product-buybox__small">Checkout via Shopify — launching soon</p>

        {d.fitment && (
          <div class="product-fitment">
            <p class="label-small hazard">Fitment & Compatibility</p>
            <dl class="product-fitment__list">
              <dt>Application</dt>
              <dd>{d.fitment.application}</dd>
              {d.fitment.daRange && (
                <>
                  <dt>Density Altitude</dt>
                  <dd class="readout">{d.fitment.daRange}</dd>
                </>
              )}
              {d.fitment.requiredMods.length > 0 && (
                <>
                  <dt>Required Mods</dt>
                  <dd>{d.fitment.requiredMods.join('; ')}</dd>
                </>
              )}
              <dt>Confidence</dt>
              <dd>{confidenceLabel[d.fitment.confidence]}</dd>
            </dl>
            {d.fitment.notes && <p class="muted product-fitment__notes">{d.fitment.notes}</p>}
          </div>
        )}

        <p class="muted product-buybox__support">
          Not sure it fits your setup? <a href={`mailto:${site.contactEmail}`} class="accent">Ask us</a> before ordering.
        </p>
      </aside>
    </div>
  </section>

  <section class="product-detail">
    <div class="wrap product-detail__wrap">
      <div class="product-detail__content">
        <div class="prose-section product-detail__prose reveal">
          <Content />
        </div>

        {d.specs.length > 0 && (
          <div class="product-specs reveal">
            <p class="label-small accent">Specs</p>
            <ul class="product-specs__list">
              {d.specs.map((s) => <li>{s}</li>)}
            </ul>
          </div>
        )}
      </div>

      <aside class="product-detail__rail reveal">
          <div class="product-detail__rail-panel">
          <p class="label-small accent">Selection notes</p>
          <p class="product-detail__rail-text">
            Stroom listings connect the part to its engine platform, supporting
            hardware, and intended use so you can narrow the choice before buying.
          </p>
          {d.manufacturerPartNumber && <p class="readout product-detail__mpn">MPN {d.manufacturerPartNumber}</p>}
          {d.referenceUrl && <a href={d.referenceUrl} class="nav-link" target="_blank" rel="noreferrer">Reference details →</a>}
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
