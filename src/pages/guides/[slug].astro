---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { render } from 'astro:content';
import { getCatalogProducts } from '../../lib/catalog';
import { getGuides } from '../../lib/editorial';
import { site } from '../../lib/site';

export async function getStaticPaths() {
  const guides = await getGuides();
  const products = await getCatalogProducts();
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: {
      guide,
      parts: guide.source === 'local'
        ? products.filter((product) => guide.entry.data.partsUsed.includes(product.slug))
        : [],
    },
  }));
}

const { guide, parts } = Astro.props;
const rendered = guide.source === 'local' ? await render(guide.entry) : undefined;
const Content = rendered?.Content;
const local = guide.source === 'local' ? guide.entry.data : undefined;
const tools = local?.tools ?? [];
const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': local?.steps.length ? 'HowTo' : 'Article',
  name: guide.title,
  headline: guide.title,
  description: guide.description,
  datePublished: guide.publishedAt,
  ...(local?.steps.length ? { step: local.steps.map((step, index) => ({ '@type': 'HowToStep', position: index + 1, name: step.name, text: step.text })) } : {}),
  publisher: { '@id': `${site.url}/#store` },
});
---

<BaseLayout title={`${guide.title} | Stroom Performance Guides`} description={guide.description} ogType="article" ogImage={guide.image} schema={`<script type="application/ld+json">${schema}<\/script>`}>
  <article class="wrap" style="padding-block:3rem 4rem;max-width:52rem;">
    <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Guides', href: '/guides' }, { label: guide.title }]} />
    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1rem;">{guide.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
    <h1 class="heading-section">{guide.title}</h1>
    <p class="body-large muted" style="margin-top:1rem;">{guide.description}</p>
    {guide.image && <img src={guide.image} alt={guide.imageAlt || ''} style="width:100%;margin-top:2rem;" />}
    <div class="prose-section" style="margin-top:2rem;border-top:1px solid var(--color-line);padding-top:2rem;border-bottom:none;">
      {Content ? <Content /> : <Fragment set:html={guide.bodyHtml} />}
    </div>
    {tools.length > 0 && <div style="margin-bottom:2.5rem;"><h2 class="heading-card">Tools</h2><ul class="muted">{tools.map((tool) => <li>{tool}</li>)}</ul></div>}
    {parts.length > 0 && <div class="altitude-panel"><p class="label-small hazard">Related parts</p><ul style="list-style:none;padding:0;">{parts.map((product) => <li><a href={`/products/${product.slug}`} class="nav-link accent">{product.title} →</a></li>)}</ul></div>}
  </article>
</BaseLayout>
