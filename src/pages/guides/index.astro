---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { site } from '../../lib/site';

const guides = (await getCollection('guides')).sort((a, b) => a.data.order - b.data.order);

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Guides & How-To — Stroom Performance',
  url: `${site.url}/guides`,
  isPartOf: { '@id': `${site.url}/#store` },
});
---

<BaseLayout
  title="Guides & How-To | Stroom Performance"
  description="High-altitude tuning, fuel-system fabrication, and data-log analysis guides from the Stroom Performance channel. Real fixes from real runs at density altitude."
  schema={`<script type="application/ld+json">${schema}<\/script>`}
>
  <section class="wrap" style="padding-block:3rem 2rem;">
    <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Guides' }]} />
    <h1 class="heading-section">Guides & How-To</h1>
    <p class="muted" style="margin-top:0.75rem;max-width:60ch;line-height:1.7;">
      The expertise behind the store. Fabrication, tuning, and data-log analysis —
      the same work you'll see on the channel, written down.
    </p>
  </section>

  <section class="wrap" style="padding-bottom:4rem;">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {guides.map((g) => (
        <a href={`/guides/${g.id}`} class="card" style="padding:1.5rem;text-decoration:none;display:flex;flex-direction:column;gap:0.75rem;">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span class="tag">{g.data.difficulty}</span>
            <span class="muted readout" style="font-size:0.75rem;">{new Date(g.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          </div>
          <h2 class="heading-card">{g.data.title}</h2>
          <p class="muted" style="font-size:0.9375rem;line-height:1.6;">{g.data.description}</p>
          <span class="nav-link accent" style="margin-top:auto;">Read guide →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
