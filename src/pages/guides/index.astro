---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { site } from '../../lib/site';
import { getGuides } from '../../lib/editorial';

const guides = await getGuides();

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Guides & How-To — Stroom Performance',
  url: `${site.url}/guides`,
  isPartOf: { '@id': `${site.url}/#store` },
});
---

<BaseLayout
  title="Guides & How-To | Stroom Performance"
  description="Performance-part fitment, installation, tuning, and build-planning guides from Stroom Performance. Make a better-informed choice before ordering."
  schema={`<script type="application/ld+json">${schema}<\/script>`}
>
  <section class="resource-hero">
    <div class="wrap resource-hero__wrap">
      <div class="resource-hero__copy">
        <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Guides' }]} />
        <p class="label-small accent reveal">Knowledge Base</p>
        <h1 class="heading-section resource-hero__title reveal">Guides & How-To</h1>
        <p class="muted resource-hero__body reveal">
          The written version of the Stroom edge: fabrication, tuning, and
          fitment, installation, tuning, and build-planning guidance tied to real parts.
        </p>
      </div>
      <aside class="resource-hero__meta reveal">
        <p class="resource-hero__meta-label">Guide Stack</p>
        <div class="resource-hero__meta-rule"></div>
        <p class="resource-hero__meta-value">{guides.length} published guides</p>
      </aside>
    </div>
  </section>

  <section class="resource-listing">
    <div class="wrap">
      <div class="resource-listing__intro reveal">
        <p class="resource-listing__text">
          These guides are part of the commercial story, not a side blog. They
          help customers understand a system and choose compatible parts.
        </p>
      </div>
      <div class="resource-card-grid">
        {guides.map((g) => (
          <a href={`/guides/${g.slug}`} class="resource-card reveal">
            <div class="resource-card__top">
              <span class="tag">{g.tags[0] || 'Guide'}</span>
              <span class="muted readout resource-card__date">{new Date(g.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            </div>
            <h2 class="heading-card">{g.title}</h2>
            <p class="muted resource-card__body">{g.description}</p>
            <span class="nav-link accent resource-card__cta">Read guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
