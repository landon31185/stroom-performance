---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { site, systems } from '../lib/site';

const valueProps = [
  {
    label: 'Audience fit',
    headline: 'The buyers are already here.',
    body: 'Stroom starts with an audience of high-intent altitude racers, not an empty storefront waiting for traffic.',
  },
  {
    label: 'Positioning moat',
    headline: 'Altitude gives the catalog a point of view.',
    body: 'Most stores stop at fitment. Stroom can explain how a part still behaves at density altitude, which is where the story becomes useful.',
  },
  {
    label: 'Content engine',
    headline: 'Builds and guides do the selling.',
    body: 'Product storytelling can be proven with race-day context, installs, and setup notes instead of copied supplier descriptions.',
  },
  {
    label: 'Model',
    headline: 'Lean drop-ship economics.',
    body: 'Suppliers keep fulfillment and inventory; Stroom brings niche authority, product framing, and a more qualified buyer.',
  },
];

const process = [
  'You tell us what product lines, terms, and fulfillment model make sense.',
  'We map those lines into the systems and race-style structure Stroom is already using.',
  'We turn the parts into guides, builds, and product pages that explain why they matter at altitude.',
];
---

<BaseLayout
  title="Wholesale & Dealer Inquiries | Stroom Performance"
  description="Manufacturers and distributors: put your performance parts in front of the high-altitude No-Prep and Index racing audience. Stroom is opening drop-ship and dealer accounts now."
>
  <section class="wholesale-hero">
    <div class="wrap wholesale-hero__wrap">
      <div class="wholesale-hero__copy">
        <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Wholesale' }]} />
        <span class="tag tag-hazard reveal">For Suppliers & Manufacturers</span>
        <h1 class="heading-hero wholesale-hero__title reveal">
          Put your parts in front of the
          <span class="wholesale-hero__accent">altitude crowd.</span>
        </h1>
        <p class="body-large muted wholesale-hero__body reveal">
          Stroom is building a specialist performance store around one clear
          niche: racers who need answers that still make sense when density
          altitude changes the pass. Before the public catalog fully opens, we
          are setting up the right supplier and dealer relationships.
        </p>
        <div class="wholesale-hero__actions reveal">
          <a href={`mailto:${site.wholesaleEmail}`} class="btn-primary">Email the Wholesale Desk</a>
          <a href={site.youtube} target="_blank" rel="noopener noreferrer" class="btn-outline">See the Channel Proof</a>
        </div>
      </div>

      <aside class="wholesale-sheet reveal" aria-label="Wholesale positioning summary">
        <p class="wholesale-sheet__eyebrow">Wholesale Positioning</p>
        <div class="wholesale-sheet__divider"></div>
        <div class="wholesale-sheet__headline">
          <span>Niche audience</span>
          <span>Race-day proof</span>
          <span>Fitment story</span>
        </div>
        <div class="wholesale-sheet__list">
          <div class="wholesale-sheet__row">
            <p class="wholesale-sheet__key">Best fit</p>
            <p class="wholesale-sheet__value">fuel, EFI, driveline, safety, altitude-sensitive setups</p>
          </div>
          <div class="wholesale-sheet__row">
            <p class="wholesale-sheet__key">Current ask</p>
            <p class="wholesale-sheet__value">dealer or drop-ship terms before full catalog launch</p>
          </div>
          <div class="wholesale-sheet__row">
            <p class="wholesale-sheet__key">Commercial angle</p>
            <p class="wholesale-sheet__value">specialist authority beats generic catalog scale</p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="wholesale-value">
    <div class="wrap">
      <div class="home-section-heading reveal">
        <p class="label-small accent">Why Partner Here</p>
        <h2 class="heading-section">This is not a mass reseller pitch. It is a relevance pitch.</h2>
      </div>
      <div class="wholesale-value__grid">
        {valueProps.map((item, index) => (
          <div class="wholesale-value-card reveal">
            <p class="home-card-index">{String(index + 1).padStart(2, '0')}</p>
            <p class="wholesale-value-card__label">{item.label}</p>
            <h2 class="heading-card">{item.headline}</h2>
            <p class="muted">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="wholesale-process">
    <div class="wrap wholesale-process__wrap">
      <div class="wholesale-process__intro reveal">
        <p class="label-small accent">How It Works</p>
        <h2 class="heading-section">Simple path now, deeper integration later.</h2>
        <p class="muted">
          The immediate goal is to start qualified conversations and structure
          the right product lines into the Stroom system before the catalog and
          commerce layer mature further.
        </p>
      </div>
      <ol class="steps-list reveal">
        {process.map((step) => (
          <li>{step}</li>
        ))}
      </ol>
    </div>
  </section>

  <section class="wholesale-form-section">
    <div class="wrap wholesale-form-section__wrap">
      <div class="wholesale-form-copy reveal">
        <p class="label-small accent">Inquiry Form</p>
        <h2 class="heading-section">Start the conversation.</h2>
        <p class="muted">
          Tell us what you make, what terms you usually offer, and which product
          lines make the most sense for a high-altitude performance audience.
        </p>
        <p class="muted wholesale-form-copy__small">
          Prefer direct email? Reach us at
          <a href={`mailto:${site.wholesaleEmail}`} class="accent">{site.wholesaleEmail}</a>.
        </p>
      </div>

      <!--
        TODO(stroom): this form is still not wired to a backend.
        Options:
          - Formspree / Basin / Web3Forms endpoint
          - Vercel serverless function in src/pages/api/
        Until then this falls back to mailto.
      -->
      <form action={`mailto:${site.wholesaleEmail}`} method="post" enctype="text/plain" class="wholesale-form reveal">
        <div class="wholesale-form__grid">
          <div class="wholesale-form__field">
            <label for="company" class="label-small muted">Company / Brand</label>
            <input id="company" name="company" type="text" required class="form-field" />
          </div>
          <div class="wholesale-form__field">
            <label for="email" class="label-small muted">Email</label>
            <input id="email" name="email" type="email" required class="form-field" />
          </div>
        </div>
        <div class="wholesale-form__field">
          <label for="systems" class="label-small muted">Closest product line</label>
          <select id="systems" name="systems" class="form-field">
            {systems.map((s) => <option value={s.slug}>{s.name}</option>)}
            <option value="other">Other</option>
          </select>
        </div>
        <div class="wholesale-form__field">
          <label for="message" class="label-small muted">Parts, terms, and fit</label>
          <textarea id="message" name="message" rows="6" class="form-field"></textarea>
        </div>
        <div class="wholesale-form__footer">
          <button type="submit" class="btn-primary">Send Inquiry</button>
          <p class="muted wholesale-form__note">Backend still TODO before full launch.</p>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
