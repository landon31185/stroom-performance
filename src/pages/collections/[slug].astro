---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCollection } from 'astro:content';
import { site } from '../../lib/site';

export async function getStaticPaths() {
  const categories = await getCollection('categories');
  const products = await getCollection('products');
  return categories.map((cat) => {
    const slug = cat.id;
    const inFacet = products
      .filter((p) =>
        cat.data.facet === 'system'
          ? p.data.system === slug
          : p.data.raceStyles.includes(slug as never),
      )
      .sort((a, b) => a.data.order - b.data.order);
    return { params: { slug }, props: { category: cat.data, slug, products: inFacet } };
  });
}

const { category, slug, products } = Astro.props;
const facetLabel = category.facet === 'system' ? 'System' : 'Racing Style';

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${category.name} — Stroom Performance`,
  url: `${site.url}/collections/${slug}`,
  description: category.description,
  isPartOf: { '@id': `${site.url}/#store` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: p.data.title,
      url: `${site.url}/products/${p.id}`,
    })),
  },
});
---

<BaseLayout
  title={`${category.name} Parts | Stroom Performance`}
  description={category.description}
  schema={`<script type="application/ld+json">${schema}<\/script>`}
>
  <section class="collection-hero">
    <div class="wrap collection-hero__wrap">
      <div class="collection-hero__copy">
        <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Shop', href: '/shop' }, { label: category.name }]} />
        <p class="label-small accent reveal">{facetLabel}</p>
        <h1 class="heading-section collection-hero__title reveal">{category.name}</h1>
        <p class="muted collection-hero__body reveal">{category.description}</p>
      </div>
      <aside class="collection-hero__meta reveal">
        <p class="collection-hero__meta-label">Collection State</p>
        <div class="collection-hero__meta-rule"></div>
        <div class="collection-hero__meta-grid">
          <div>
            <p class="collection-hero__meta-key">Items</p>
            <p class="collection-hero__meta-value">{products.length}</p>
          </div>
          <div>
            <p class="collection-hero__meta-key">Use case</p>
            <p class="collection-hero__meta-value">{facetLabel}</p>
          </div>
          <div>
            <p class="collection-hero__meta-key">Model</p>
            <p class="collection-hero__meta-value">curated, not bulk</p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="collection-results">
    <div class="wrap">
      {products.length > 0 ? (
        <>
          <div class="collection-results__intro reveal">
            <p class="label-small accent">Current Listings</p>
            <p class="collection-results__text">
              Placeholder catalog now, but the structure is the point: parts are
              grouped by real system and real racing context, not just generic
              shelf category names.
            </p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {products.map((p) => (
              <ProductCard slug={p.id} title={p.data.title} brand={p.data.brand} system={p.data.system} platforms={p.data.platforms} summary={p.data.summary} availability={p.data.availability} price={p.data.price} />
            ))}
          </div>
        </>
      ) : (
        <div class="collection-empty reveal">
          <p class="heading-card">Parts coming soon</p>
          <p class="muted">
            Supplier accounts for this category are still opening. If you build
            for this niche, <a href="/wholesale" class="accent">start a wholesale inquiry →</a>
          </p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
