---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import HeroAtmosphere from '../components/HeroAtmosphere';
import HeroFilmLayer from '../components/HeroFilmLayer.astro';
import { getCollection } from 'astro:content';
import { site, systems } from '../lib/site';

const products = await getCollection('products');
const featured = products.filter((p) => p.data.featured).sort((a, b) => a.data.order - b.data.order);
const guides = (await getCollection('guides')).sort((a, b) => a.data.order - b.data.order).slice(0, 3);

const heroHighlights = [
  { label: 'Current platform', value: 'GM LS' },
  { label: 'Current systems', value: 'Engine + EFI' },
  { label: 'Next platform', value: 'Gen III Hemi' },
];

const trustPillars = [
  {
    title: 'Curated instead of crowded',
    body: 'The store should feel like a focused shelf of parts worth considering, not a giant feed with no judgment behind it.',
  },
  {
    title: 'Guidance tied to what you buy',
    body: 'Guides, builds, and product notes should reduce wrong turns before checkout, not live as disconnected content.',
  },
  {
    title: 'Real-world perspective',
    body: 'Stroom still gets to use race-day experience as proof, but now it supports the store instead of taking over the whole homepage.',
  },
];

const featuredSpotlight = featured[0];
const supportSpotlights = featured.slice(1, 3);
---

<BaseLayout
  title="Stroom Performance — Premium Performance Parts"
  description="Curated performance parts, fitment-minded guidance, and cleaner category entry points for builders who want more confidence and less guesswork."
>
  <section class="home-hero">
    <HeroAtmosphere client:load />
    <div class="wrap home-hero__wrap">
      <div class="home-hero__copy">
        <div class="home-hero__intro">
          <h1 class="heading-hero home-hero__title reveal">
            Serious parts.
            <span class="home-hero__title-accent">Clearer choices.</span>
          </h1>
          <p class="body-large muted reveal home-hero__body">
            <span class="home-hero__body-desktop">
              Explore verified GM LS components with the fitment details and
              system context needed to make a confident choice.
            </span>
            <span class="home-hero__body-mobile">
              Fitment-minded parts and guidance for GM LS and Gen III Hemi builds.
            </span>
          </p>
          <div class="home-hero__actions reveal">
            <a href="/shop" class="btn-primary">Shop Parts</a>
            <a href="/guides" class="btn-outline">Browse Guides</a>
          </div>
        </div>
        <div class="home-proof reveal" aria-label="Homepage highlights">
          {heroHighlights.map((item) => (
            <div class="home-proof__item">
              <p class="home-proof__label">{item.label}</p>
              <p class="home-proof__value">{item.value}</p>
            </div>
          ))}
        </div>
      </div>

      {site.heroFilm.enabled && <HeroFilmLayer src={site.heroFilm.src} poster={site.heroFilm.poster} />}

      <aside class="home-hero-panel reveal" aria-label="Featured focus">
        <div class="home-hero-panel__top"><p class="home-hero-panel__stamp">Choose a platform</p></div>
        <div class="home-hero-panel__divider"></div>
        <div class="home-hero-panel__headline">
          <span>Start with</span>
          <span>your build.</span>
        </div>
        <p class="home-hero-panel__body">
          Find compatible parts by platform first, then narrow the choice by
          system, use case, and the rest of the combination.
        </p>
        <div class="home-hero-panel__stack">
          <a href="/shop#gm-ls" class="home-hero-panel__card">
            <span class="home-hero-panel__card-label">Verified first</span>
            <strong>Shop GM LS parts and fitment details.</strong>
          </a>
          <a href="/shop#gen3-hemi" class="home-hero-panel__card">
            <span class="home-hero-panel__card-label">Next platform</span>
            <strong>Explore the Gen III Hemi collection as it grows.</strong>
          </a>
          <a href="/builds" class="home-hero-panel__card">
            <span class="home-hero-panel__card-label">Build context</span>
            <strong>See how parts work together before choosing one.</strong>
          </a>
        </div>
      </aside>
    </div>
  </section>

  <section class="home-system-rail">
    <div class="wrap home-system-rail__wrap">
      <div class="home-section-heading reveal home-section-heading--split home-section-heading--inline">
        <div>
          <h2 class="heading-section">Start with the part of the build you are solving.</h2>
        </div>
        <a href="/shop" class="nav-link">View all categories →</a>
      </div>
      <div class="home-system-rail__grid">
        {systems.map((s, index) => (
          <a href={`/collections/${s.slug}`} class="home-system-tile reveal">
            <span class="home-system-tile__index">{String(index + 1).padStart(2, '0')}</span>
            <div class="home-system-tile__content">
              <h3 class="heading-card">{s.name}</h3>
              <p class="muted">{s.blurb}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-credibility">
    <div class="wrap">
      <div class="home-section-heading reveal">
        <h2 class="heading-section">A premium store should make the next choice feel easier.</h2>
      </div>
      <div class="home-credibility__grid home-credibility__grid--wide">
        {trustPillars.map((item, index) => (
          <div class="home-editorial-card reveal">
            <p class="home-card-index">{String(index + 1).padStart(2, '0')}</p>
            <h3 class="heading-card">{item.title}</h3>
            <p class="muted">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="home-spotlight">
    <div class="wrap home-spotlight__wrap">
      <div class="home-section-heading reveal home-section-heading--split home-section-heading--inline">
        <div>
          <h2 class="heading-section">Parts selected around the complete build.</h2>
        </div>
        <div class="home-spotlight__controls reveal" aria-hidden="true">
          <span class="home-spotlight__arrow">←</span>
          <span class="home-spotlight__arrow">→</span>
        </div>
      </div>
      <div class="home-spotlight__grid">
        {featuredSpotlight && (
          <a href={`/products/${featuredSpotlight.id}`} class="home-spotlight__feature reveal">
            <h3 class="home-spotlight__title">{featuredSpotlight.data.title}</h3>
            <p class="home-spotlight__body">{featuredSpotlight.data.summary}</p>
            <span class="home-spotlight__cta">View product →</span>
          </a>
        )}
        <div class="home-spotlight__stack">
          {supportSpotlights.map((p) => (
            <a href={`/products/${p.id}`} class="home-spotlight__mini reveal">
              <h3 class="heading-card">{p.data.title}</h3>
              <p class="muted">{p.data.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="home-parts">
    <div class="wrap">
      <div class="home-section-heading reveal home-section-heading--split">
        <div>
          <h2 class="heading-section">Start with verified GM LS components.</h2>
        </div>
        <a href="/shop" class="nav-link">See all →</a>
      </div>
      <p class="muted home-section-copy reveal">
        Review manufacturer part numbers, core specifications, and combination-dependent
        fitment notes before these products become available to purchase through Stroom.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featured.map((p) => (
          <ProductCard slug={p.id} title={p.data.title} brand={p.data.brand} system={p.data.system} platforms={p.data.platforms} summary={p.data.summary} availability={p.data.availability} price={p.data.price} partNumber={p.data.manufacturerPartNumber} image={p.data.image} />
        ))}
      </div>
    </div>
  </section>

  <section class="home-guides">
    <div class="wrap home-guides__wrap">
      <div class="home-section-heading reveal home-section-heading--split">
        <div>
          <h2 class="heading-section">When the customer knows the problem, the site should point them forward.</h2>
        </div>
        <a href="/guides" class="nav-link">All guides →</a>
      </div>
      <div class="home-guides__grid">
        {guides.map((g) => (
          <a href={`/guides/${g.id}`} class="home-guide-card reveal">
            <h3 class="heading-card">{g.data.title}</h3>
            <p class="muted">{g.data.description}</p>
            <span class="home-guide-card__link">Open guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-assortment">
    <div class="wrap">
      <div class="home-assortment__panel reveal">
        <div class="home-assortment__intro">
          <h2 class="heading-section">Build around the system, not a random parts list.</h2>
          <p class="muted">
            Start with the platform and problem you are solving. Stroom connects
            individual parts to the engine, fuel, electronics, and drivetrain
            decisions that determine whether the combination works.
          </p>
        </div>
        <div class="home-assortment__grid">
          <a href="/shop" class="home-assortment__cell">
            <strong>Shop by system, not by guesswork.</strong>
          </a>
          <a href="/guides" class="home-assortment__cell">
            <strong>Use content as a buying tool, not background noise.</strong>
          </a>
          <a href="/builds" class="home-assortment__cell">
            <strong>Keep proof and product context connected.</strong>
          </a>
        </div>
        <div class="home-assortment__footer">
          <a href="/about" class="btn-outline">Why Stroom</a>
          <a href="/shop" class="nav-link">Browse all parts →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="home-postscript">
    <div class="wrap home-postscript__wrap reveal">
      <div class="home-postscript__rule"></div>
      <p class="home-postscript__text">
        Serious parts. Clear fitment. Better decisions before checkout.
      </p>
    </div>
  </section>
</BaseLayout>
