---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found | Stroom Performance" description="That page doesn't exist. Head back to the shop or the guides." noindex>
  <section class="wrap" style="padding-block:6rem;text-align:center;min-height:50vh;">
    <p class="readout accent" style="font-size:3rem;font-weight:700;">404</p>
    <h1 class="heading-section" style="margin-top:0.5rem;">Off the groove.</h1>
    <p class="muted" style="margin-top:0.75rem;">That page doesn't exist. Line back up:</p>
    <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;margin-top:1.5rem;">
      <a href="/" class="btn-primary">Home</a>
      <a href="/shop" class="btn-outline">Shop</a>
      <a href="/guides" class="btn-outline">Guides</a>
    </div>
  </section>
</BaseLayout>
