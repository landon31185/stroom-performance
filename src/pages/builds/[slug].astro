---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { render } from 'astro:content';
import { getCatalogProducts } from '../../lib/catalog';
import { getBuilds } from '../../lib/editorial';
import { platformName, raceStyleName, site } from '../../lib/site';

export async function getStaticPaths() {
  const builds = await getBuilds();
  const products = await getCatalogProducts();
  return builds.map((build) => ({
    params: { slug: build.slug },
    props: { build, parts: products.filter((product) => build.partsUsed.includes(product.slug)) },
  }));
}

const { build, parts } = Astro.props;
const rendered = build.source === 'local' ? await render(build.entry) : undefined;
const Content = rendered?.Content;
const schema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'Article', headline: build.title,
  description: build.description, url: `${site.url}/builds/${build.slug}`,
  publisher: { '@id': `${site.url}/#store` },
});
---

<BaseLayout title={`${build.title} | Stroom Performance`} description={build.description} ogType="article" ogImage={build.image} schema={`<script type="application/ld+json">${schema}<\/script>`}>
  <article class="wrap" style="padding-block:3rem 4rem;max-width:52rem;">
    <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Builds', href: '/builds' }, { label: build.title }]} />
    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1rem;">
      {build.platforms.map((platform) => <span class="tag tag-platform">{platformName(platform)}</span>)}
      {build.raceStyles.map((style) => <span class="tag tag-hazard">{raceStyleName(style)}</span>)}
      {build.videoUrl && <a href={build.videoUrl} target="_blank" rel="noopener noreferrer" class="tag">Watch video</a>}
    </div>
    <h1 class="heading-section">{build.title}</h1>
    <p class="body-large muted" style="margin-top:1rem;">{build.description}</p>
    {build.image && <img src={build.image} alt={build.imageAlt || ''} style="width:100%;margin-top:2rem;" />}
    {build.vehicle && <div class="card" style="padding:1rem;margin-top:1.5rem;"><p class="muted label-small">Vehicle</p><p style="margin-top:0.25rem;">{build.vehicle}</p></div>}
    <div class="prose-section" style="margin-top:2rem;border-top:1px solid var(--color-line);padding-top:2rem;border-bottom:none;">
      {Content ? <Content /> : <Fragment set:html={build.bodyHtml} />}
    </div>
    {parts.length > 0 && <div class="altitude-panel"><p class="label-small hazard">Parts on this build</p><ul style="list-style:none;padding:0;">{parts.map((product) => <li><a href={`/products/${product.slug}`} class="nav-link accent">{product.title} →</a></li>)}</ul></div>}
  </article>
</BaseLayout>
