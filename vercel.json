{
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/((?!_astro|api).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        },
        {
          "key": "No-Vary-Search",
          "value": "params=(utm_source utm_medium utm_campaign utm_content utm_term fbclid gclid)"
        }
      ]
    }
  ]
}
